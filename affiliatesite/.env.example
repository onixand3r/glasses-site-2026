# Ghost CMS Configuration
# Get these from Ghost Admin > Settings > Integrations > Add Integration
GHOST_API_URL=http://localhost:2368
GHOST_CONTENT_API_KEY=your-content-api-key-here

# Ghost Public URLs (for production)
GHOST_URL=https://your-domain.com
GHOST_ADMIN_URL=https://your-domain.com

# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PASSWORD=ghostpass

# SMTP Configuration (optional - for Ghost emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
